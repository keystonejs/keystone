datasource sqlite {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

model Post {
  id                  String  @id @default(cuid())
  title               String  @default("")
  content             String  @default("")
  banner_id           String?
  banner_extension    String?
  banner_filesize     Int?
  banner_width        Int?
  banner_height       Int?
  attachment_filesize Int?
  attachment_filename String?
}
