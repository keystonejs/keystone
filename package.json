{
  "name": "@keystone-6/mono-repo",
  "description": "KeystoneJS monorepo for all the @keystone-6 packages",
  "author": "Thinkmill Labs Pty Ltd",
  "private": true,
  "version": null,
  "license": "MIT",
  "repository": "https://github.com/keystonejs/keystone",
  "homepage": "https://github.com/keystonejs/keystone",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "test:vitest": "vitest run ./packages/fields-document",
    "test:filters": "cd prisma-utils && pnpm verify",
    "test:types": "tsc",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:admin-ui": "vitest run tests/admin-ui-tests",
    "test:node": "node --import tsx --test --test-concurrency 4 tests2/*.test.ts",
    "test:node:only": "node --import tsx --test-only tests2/*.test.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "build": "preconstruct build",
    "postinstall": "preconstruct dev && pnpm -r check",
    "resolve:create-starter-catalog": "node scripts/resolve-create-starter-catalog.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/plugin-transform-runtime": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "@babel/preset-typescript": "^7.24.7",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.18.0",
    "@changesets/get-github-info": "^0.8.0",
    "@changesets/get-release-plan": "^4.0.0",
    "@preconstruct/cli": "^2.8.9",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "esbuild": "^0.28.0",
    "oxlint": "^1.75.0",
    "prettier": "^3.5.1",
    "tsx": "^4.0.0",
    "typescript": "catalog:",
    "vite": "^6.0.0",
    "vitest": "^4.0.0",
    "yaml": "^2.8.3"
  },
  "preconstruct": {
    "packages": [
      "packages/*",
      "design-system/packages/*"
    ],
    "exports": true,
    "___experimentalFlags_WILL_CHANGE_IN_PATCH": {
      "keepDynamicImportAsDynamicImportInCommonJS": true,
      "importsConditions": true
    }
  }
}
